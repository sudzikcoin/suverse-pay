{
  "name": "@suverse-pay/provider-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Base adapter class + HTTP / retry / timeout utilities shared by all suverse-pay provider adapters.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@suverse-pay/core-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
