{
  "name": "@suverse-pay/adapter-t402-io",
  "version": "0.0.0",
  "private": true,
  "description": "Adapter wrapping t402-io's universal USDT facilitator. Provides EVM/Solana/Cosmos USDT routing through their hosted facilitator + capability advertising for 6 additional VM namespaces (TON, NEAR, Aptos, Tezos, Polkadot, Stacks, Stellar).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@suverse-pay/core-types": "workspace:*",
    "@suverse-pay/provider-sdk": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
