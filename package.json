{
  "name": "suverse-pay",
  "version": "0.1.0-rc.1",
  "private": true,
  "description": "Unified payment gateway for the x402 protocol — Stripe-like API for all x402 facilitators.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudzikcoin/suverse-pay.git"
  },
  "homepage": "https://github.com/sudzikcoin/suverse-pay#readme",
  "bugs": "https://github.com/sudzikcoin/suverse-pay/issues",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "db:migrate": "pnpm --filter @suverse-pay/db run migrate",
    "db:bootstrap": "pnpm --filter @suverse-pay/db run bootstrap",
    "test:integration": "pnpm --filter @suverse-pay/api run test:integration",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}
