{
  "name": "@suverse-pay/proxy",
  "version": "0.0.0",
  "private": true,
  "description": "Self-serve x402 proxy — wraps any upstream HTTP API behind a paid /v1/proxy/<seller>/<slug> endpoint without seller-side code.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.2.1",
    "@suverselabs/x402-client": "workspace:*",
    "@suverselabs/x402-server": "workspace:*",
    "@x402/extensions": "2.14.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
