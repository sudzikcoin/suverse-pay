# --- Suverse Pay Customer Dashboard ---
# Copy to .env.local for local dev; configure in deployment platform
# (Vercel env vars, etc.) for production.

# Postgres — shared schema with apps/api. The dashboard reads
# facilitator_payments / resource_api_keys + writes its own
# dashboard_users / dashboard_user_resource_keys tables.
DATABASE_URL=postgres://suverse:suverse@localhost:5433/suverse_pay

# NextAuth.js
# NEXTAUTH_URL is the canonical origin of this dashboard:
#   - local dev:   http://localhost:3002
#   - production:  https://suverse-pay.suverse.io
NEXTAUTH_URL=http://localhost:3002
# Random 32+ byte secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32

# --- OAuth providers ---

# Google OAuth 2.0 — console.cloud.google.com
#   Project > APIs & Services > Credentials > Create OAuth client (Web)
#   Authorized redirect URIs (add BOTH for local + prod):
#     http://localhost:3002/api/auth/callback/google
#     https://suverse-pay.suverse.io/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth App — github.com/settings/developers
#   New OAuth App
#   Authorization callback URL (one per app — register two apps if
#   you need both local + prod, OR use a single app pointing at prod
#   and tunnel locally via something like cloudflared):
#     https://suverse-pay.suverse.io/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
