          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT rk.label AS resource_key, COUNT(*) FILTER (WHERE fp.status = 'settled') AS settled, COUNT(*) FILTER (WHERE fp.status = 'failed') AS failed FROM resource_api_keys rk LEFT JOIN facilitator_payments fp ON fp.resource_key_id = rk.id GROUP BY rk.label ORDER BY settled DESC NULLS LAST",
          "refId": "A"
        }
      ],
