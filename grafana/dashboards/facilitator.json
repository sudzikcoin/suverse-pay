          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT adapter_used AS adapter, error_code, COUNT(*) AS occurrences FROM facilitator_payments WHERE status = 'failed' AND created_at > NOW() - INTERVAL '24 hours' GROUP BY adapter_used, error_code ORDER BY occurrences DESC LIMIT 25",
