      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "suverse_pay_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT e.created_at, e.primary_adapter AS from_adapter, e.backup_adapter AS to_adapter, fp.network, e.primary_error_code AS error, e.payment_id FROM facilitator_failover_events e JOIN facilitator_payments fp ON fp.id = e.payment_id WHERE e.created_at > NOW() - INTERVAL '24 hours' ORDER BY e.created_at DESC LIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Failover events (last 24h)",
      "type": "table"
    },
