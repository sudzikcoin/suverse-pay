    {
      "datasource": { "type": "postgres", "uid": "suverse_pay_pg" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } }
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 38 },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "suverse_pay_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT rk.label AS resource_key, fp.network, COALESCE(SUM(CASE WHEN fp.status = 'settled' THEN fp.amount::numeric ELSE 0 END), 0) / 1000000 AS volume_usdc, COUNT(*) FILTER (WHERE fp.status = 'settled') AS settled, COUNT(*) FILTER (WHERE fp.status = 'failed') AS failed FROM resource_api_keys rk JOIN facilitator_payments fp ON fp.resource_key_id = rk.id WHERE fp.created_at > NOW() - INTERVAL '7 days' GROUP BY rk.label, fp.network ORDER BY volume_usdc DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Top resource keys by volume (7d)",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "suverse_pay_pg" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } }
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 38 },
      "id": 12,
