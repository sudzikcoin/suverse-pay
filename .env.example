NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=3000
ADMIN_API_KEY=replace-me-with-a-long-random-string

# Database — non-default port to avoid colliding with a host-level
# Postgres on 5432 (e.g. an existing govhub deployment on the same VM).
DATABASE_URL=postgres://suverse:suverse@localhost:5433/suverse_pay

# Redis — non-default port for the same reason.
REDIS_URL=redis://localhost:6380

# Provider: cosmos-pay
COSMOS_PAY_BASE_URL=http://localhost:8402

# Provider: coinbase-cdp
# These vars are adapter-internal. CDP's x402 facilitator authenticates
# every request with a short-lived JWT signed by the API key secret. The
# adapter constructs the JWT internally (jose + Ed25519). Generate the
# key pair at https://portal.cdp.coinbase.com/ — the "Key name" lands in
# COINBASE_CDP_API_KEY_NAME and the multi-line base64 secret lands in
# COINBASE_CDP_API_KEY_SECRET. ECDSA (legacy) keys are not yet supported.
COINBASE_CDP_API_KEY_NAME=
COINBASE_CDP_API_KEY_SECRET=
COINBASE_CDP_MONTHLY_HARD_CAP=5000
# Optional override; defaults to https://api.cdp.coinbase.com/platform/v2/x402
COINBASE_CDP_BASE_URL=

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# docker-compose host port mappings. 5433/6380 default to avoid
# colliding with host-level Postgres/Redis already on 5432/6379.
POSTGRES_PORT=5433
REDIS_PORT=6380

# Platform fee (Phase 5 Block 4 Sub-task 3).
# PLATFORM_FEE_BPS — basis points withheld from every /facilitator/settle
# (accounting only — NOT collected on-chain in v1; the dashboard
# exports a monthly invoice CSV for out-of-band settlement). Default
# 30 = 0.3%. Range 0..1000. Per-key override is in
# resource_api_keys.fee_bps. See PRICING.md.
PLATFORM_FEE_BPS=30
# Reserved for the future on-chain collection path (splitter contract
# or native facilitator). Unused in v1 — set ahead of time so a
# future deploy doesn't need a .env change.
PLATFORM_FEE_PAYOUT_ADDRESS=
