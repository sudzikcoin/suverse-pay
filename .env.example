NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=3000
ADMIN_API_KEY=replace-me-with-a-long-random-string

# Database
DATABASE_URL=postgres://suverse:suverse@localhost:5432/suverse_pay

# Redis
REDIS_URL=redis://localhost:6379

# Provider: cosmos-pay
COSMOS_PAY_BASE_URL=http://localhost:8402

# Provider: coinbase-cdp
# These vars are adapter-internal. CDP's x402 facilitator authenticates
# every request with a short-lived JWT signed by the API key secret. The
# adapter constructs the JWT internally (jose + Ed25519). Generate the
# key pair at https://portal.cdp.coinbase.com/ — the "Key name" lands in
# COINBASE_CDP_API_KEY_NAME and the multi-line base64 secret lands in
# COINBASE_CDP_API_KEY_SECRET. ECDSA (legacy) keys are not yet supported.
COINBASE_CDP_API_KEY_NAME=
COINBASE_CDP_API_KEY_SECRET=
COINBASE_CDP_MONTHLY_HARD_CAP=5000
# Optional override; defaults to https://api.cdp.coinbase.com/platform/v2/x402
COINBASE_CDP_BASE_URL=

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# docker-compose host ports (override if 5432/6379 conflict with system services)
POSTGRES_PORT=5432
REDIS_PORT=6379
