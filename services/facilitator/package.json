{
  "name": "@suverse-pay/facilitator",
  "version": "0.0.0",
  "private": true,
  "description": "Public x402 facilitator surface — routing, failover, idempotency, rate limiting for resource-server-facing /facilitator/* endpoints.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
