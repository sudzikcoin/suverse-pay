    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@suverse-pay/core-types": "workspace:*",
    "@suverse-pay/db": "workspace:*",
    "@suverse-pay/orchestrator": "workspace:*",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.10",
    "vitest": "^4.1.7"
  }
}
